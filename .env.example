# =================================================================
# EyeQ AI — environment configuration
# Copy this file to `.env.local` for local development.
# Production secrets live in Vercel / Supabase project settings.
# Never commit `.env.local` or any file containing real secrets.
# Placeholders only — replace with your own values locally / in Vercel.
# =================================================================

# ---------- Application ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="EyeQ AI"
NODE_ENV="development"
APP_ENV="development"   # development | test | staging | demo | production
# Vercel sales / shared Live Demo host: APP_ENV=demo (required) + DEMO_MODE=true
# PHI pilot / production: APP_ENV=production + DEMO_MODE=false (never both demo + production)

# ---------- Environment safety ----------
DEMO_MODE="true"                 # alias for FEATURE_DEMO_MODE; APP_ENV=demo also enables when unset
FEATURE_DEMO_MODE="true"           # false in PHI production — isolates demo tenant workflows
# Optional: absolute demo host for marketing CTAs when marketing ≠ demo app
# NEXT_PUBLIC_DEMO_URL="https://demo.your-domain.com"
ALLOW_SEED_DATA="false"            # never true in production
ALLOW_SIMULATED_CLAIMS="false"     # only true in isolated demo/dev with CLEARINGHOUSE_ENABLED
ALLOW_SIMULATED_PAYMENTS="false"
ALLOW_TEST_MESSAGES="false"

# ---------- PostgreSQL (Supabase Postgres or any Postgres 14+) ----------
# Direct connection — used by Prisma migrate / studio.
DIRECT_URL="postgresql://postgres:password@localhost:5432/eyeqai?schema=public"
# Pooled connection — used by Prisma client at runtime (PgBouncer).
# Session pooler (port 5432) — use connection_limit=1 per Node process in local dev.
# Supabase session mode caps total pool clients (~15); multiple Prisma instances
# or high connection_limit values exhaust the pool quickly.
# For serverless (Vercel) production, use transaction pooler on 6543 with
# `?pgbouncer=true&connection_limit=1`.
DATABASE_URL="postgresql://postgres:password@localhost:5432/eyeqai?schema=public&connection_limit=1&pool_timeout=20"

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET_IMAGING="imaging"
SUPABASE_STORAGE_BUCKET_DOCUMENTS="documents"

# ---------- Imaging analysis (server-only — never expose API keys to client) ----------
# manual | descriptive | external | custom | development-mock
# descriptive = OpenAI Vision descriptive review (requires OPENAI_API_KEY)
IMAGING_PROVIDER_MODE="descriptive"
IMAGING_ANALYSIS_MODE="descriptive"
IMAGING_AUTO_DESCRIPTIVE="true"
IMAGING_ANALYSIS_ENDPOINT=""
IMAGING_ANALYSIS_API_KEY=""
IMAGING_CUSTOM_ENDPOINT=""
IMAGING_CUSTOM_API_KEY=""
IMAGING_AI_PROVIDER=""
IMAGING_AI_API_KEY=""
IMAGING_AI_BAA_CONFIRMED="false"
# Only true in local dev with explicit opt-in — shows "Development Mock Analysis" badge
IMAGING_DEV_MOCK="false"
ENABLE_DEVELOPMENT_AI_MOCKS="false"

# ---------- AI providers (server-only — never expose to browser) ----------
AI_PROVIDER="openai"   # one of: mock | openai | anthropic
AI_MODE="openai"       # prefer openai | mock | disabled
AI_HIPAA_MODE="true"
AI_BAA_CONFIRMED="false"
OPENAI_BAA_CONFIRMED="false"
ANTHROPIC_BAA_CONFIRMED="false"
AI_ALLOW_PHI="false"
AI_REQUIRE_PROVIDER_REVIEW="true"
AI_LOGGING_MODE="redacted"   # redacted | off | full (never full in prod)
AI_LOG_REDACTED_ONLY="true"
AI_EMERGENCY_SHUTDOWN="false"
AI_DAILY_COST_LIMIT=""
AI_MONTHLY_COST_LIMIT=""
AI_REQUEST_TIMEOUT="30000"
AI_MAX_RETRIES="1"
AI_FALLBACK_PROVIDER=""
AI_FALLBACK_MODEL=""
OPENAI_API_KEY=""
OPENAI_VISION_MODEL="gpt-4o"
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"
NEXT_PUBLIC_AI_PROVIDER="mock"   # UI badge only — not a secret
TRANSCRIPTION_PROVIDER=""
TRANSCRIPTION_API_KEY=""
TRANSCRIPTION_BAA_CONFIRMED="false"
TRANSCRIPTION_STORE_AUDIO="false"
EMBEDDING_PROVIDER="openai"
EMBEDDING_MODEL="text-embedding-3-small"

# ---------- Communications (Release 2) ----------
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
TWILIO_BAA_CONFIRMED="false"
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""
SENDGRID_BAA_CONFIRMED="false"

# ---------- Background jobs ----------
JOB_PROCESSOR_SECRET=""   # Bearer token for POST /api/jobs/process

# ---------- Billing / clearinghouse / SaaS membership ----------
CLEARINGHOUSE_ENABLED="false"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Stripe Price IDs for practice membership (Dashboard → Products → Prices)
STRIPE_PRICE_PILOT=""
STRIPE_PRICE_PRACTICE=""
STRIPE_PRICE_GROWTH=""
STRIPE_PRICE_ENTERPRISE=""
# Days after PAST_DUE before new invites/locations are blocked (clinical access stays)
BILLING_GRACE_PERIOD_DAYS="7"

# ---------- Google Business / reputation ----------
GOOGLE_BUSINESS_API_KEY=""
GOOGLE_BUSINESS_ACCOUNT_ID=""

# ---------- Audit external sink ----------
AUDIT_WEBHOOK_URL=""
AUDIT_WEBHOOK_SECRET=""

# ---------- Audit / observability ----------
AUDIT_LOG_SINK="db"  # db | stdout | external
ERROR_TRACKING_PROVIDER=""   # e.g. sentry | none
ERROR_TRACKING_DSN=""        # server-only — never expose to client
MONITORING_WEBHOOK_URL=""
SENTRY_DSN=""                # legacy alias if used by tooling; prefer ERROR_TRACKING_DSN

# ---------- Feature flags ----------
FEATURE_PATIENT_PORTAL="true"
FEATURE_AI_IMAGING_REVIEW="true"
FEATURE_MULTI_LOCATION="true"
