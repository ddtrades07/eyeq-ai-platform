  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patientId       String
  patient         Patient      @relation("ProxyPatient", fields: [patientId], references: [id], onDelete: Cascade)
  guardianUserId  String
  guardianUser    User         @relation("GuardianProxyAccess", fields: [guardianUserId], references: [id], onDelete: Cascade)
  relationship    String
  accessLevel     String       @default("read") // read | limited | full
  expiresAt       DateTime?
  consentRecordId String?
  consentNotes    String?      @db.Text
  revokedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([patientId, guardianUserId])
  @@index([organizationId])
  @@index([guardianUserId])
}

// =================================================================
//                    VENDOR / BAA READINESS TRACKING
// =================================================================

model VendorReadiness {
  id               String                 @id @default(cuid())
  organizationId   String
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor           VendorKind
  status           VendorReadinessStatus  @default(NOT_CONFIGURED)
  baaCompletedAt   DateTime?
  baaCompletedById String?
  lastTestAt       DateTime?
  lastTestOk       Boolean?
  lastError        String?                @db.Text
  notes            String?                @db.Text
  /// Never store raw secrets. Optional last-4 / hint only.
  configHint       String?
  updatedAt        DateTime               @updatedAt
  createdAt        DateTime               @default(now())

  @@unique([organizationId, vendor])
  @@index([organizationId, status])
}

// =================================================================
//                      STAFF ONBOARDING CHECKLIST
// =================================================================

model StaffOnboarding {
  id                    String       @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId                String       @unique
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  inviteAcceptedAt      DateTime?
  passwordSetAt       DateTime?
  mfaEnrolledAt         DateTime?
  roleConfirmedAt       DateTime?
  locationAccessConfirmedAt DateTime?
  permissionsReviewedAt DateTime?
  phiNoticeAcceptedAt   DateTime?
  workflowIntroCompletedAt DateTime?
  completedAt           DateTime?
  notes                 String?      @db.Text
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([organizationId, completedAt])
}

// =================================================================
//                         SUPPORT TICKETS
// =================================================================

enum SupportTicketCategory {
  LOGIN
  MFA
  SCHEDULING
  PATIENT_CHART
  IMAGING
  AI
  MESSAGING
  REMINDERS
  PATIENT_PORTAL
  BILLING
  GOOGLE_REVIEWS
  MIGRATION
  BUG
  FEATURE_REQUEST
  OTHER
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

model SupportTicket {
  id               String                 @id @default(cuid())
  organizationId   String
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById      String
  createdBy        User                   @relation("SupportTicketCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignedToId     String?
  assignedTo       User?                  @relation("SupportTicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  category         SupportTicketCategory
  priority         SupportTicketPriority  @default(NORMAL)
  status           SupportTicketStatus    @default(OPEN)
  subject          String
  description      String                 @db.Text
  /// Submitter attested that the ticket body may include PHI.
  mayContainPhi    Boolean                @default(false)
  /// Platform admin flagged a security / PHI concern.
  securityConcern  Boolean                @default(false)
  relatedPatientId String?
  resolution       String?                @db.Text
  resolvedAt       DateTime?
  closedAt         DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  notes            SupportTicketNote[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([assignedToId])
}

model SupportTicketNote {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String
  author      User          @relation("SupportTicketNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body        String        @db.Text
  /// Internal notes are not shown to the submitting practice staff.
  isInternal  Boolean       @default(true)
  createdAt   DateTime      @default(now())

  @@index([ticketId, createdAt])
}

// =================================================================
//                    SAAS SUBSCRIPTION / USAGE
// =================================================================

enum SaasPlan {
  PILOT
  PRACTICE
  GROWTH
  ENTERPRISE
}

enum SaasBillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  MANUAL
}

/// Org-level SaaS plan + usage counters. Billing issues alert admins only —
/// they must not hard-block clinical access.
model OrgSubscription {
  id                 String            @id @default(cuid())
  organizationId     String            @unique
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan               SaasPlan          @default(PILOT)
  billingStatus      SaasBillingStatus @default(MANUAL)
  providerSeatLimit  Int               @default(5)
  locationSeatLimit  Int               @default(2)
  aiActionsUsed      Int               @default(0)
  aiActionsLimit     Int?
  scribeMinutesUsed  Int               @default(0)
  scribeMinutesLimit Int?
  smsRemindersUsed   Int               @default(0)
  smsRemindersLimit  Int?
  storageMbUsed      Int               @default(0)
  storageMbLimit     Int?
  nextInvoiceAt      DateTime?
  adminAlertNote     String?           @db.Text
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

