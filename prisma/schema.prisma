// EyeQ AI — Prisma schema
// Multi-tenant, optometry-first SaaS data model.
// Every clinical/operational row is scoped by `organizationId`.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

