  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([patientId, createdAt])
  @@index([resourceType, resourceId])
  @@index([action, createdAt])
}

// =================================================================
//                      EHR INTEGRATION CENTER
//
// Each row represents one configured connection between a practice and
// an external EHR. Real production deployments will store OAuth tokens
// in a vault — they are *not* stored on this model.
// =================================================================

model EhrIntegration {
  id                  String                @id @default(cuid())
  organizationId      String
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor              ConnectedEhrVendor
  displayName         String
  connectorMethod     EhrConnectorMethod    @default(FHIR)
  status              EhrConnectionStatus   @default(NOT_CONNECTED)
  syncDirection       EhrSyncDirection      @default(NONE)
  // Capability matrix (true = this integration supports the resource).
  patientSync         Boolean               @default(false)
  appointmentSync     Boolean               @default(false)
  noteExport          Boolean               @default(false)
  prescriptionSync    Boolean               @default(false)
  imagingMetadataSync Boolean               @default(false)
  // Connection bookkeeping. Tokens belong in a vault — never here.
  baseUrl             String?
  scopes              String[]              @default([])
  sandboxOnly         Boolean               @default(true)
  setupChecklist      Json?                 // [{label, done, owner}]
  lastSyncAt          DateTime?
  lastErrorAt         DateTime?
  lastErrorMessage    String?
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  syncLogs            EhrSyncLog[]

  @@index([organizationId, vendor])
}

model EhrSyncLog {
  id              String          @id @default(cuid())
  integrationId   String
  integration     EhrIntegration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  startedAt       DateTime        @default(now())
  finishedAt      DateTime?
  resourceType    String          // "Patient" | "Appointment" | etc.
  direction       EhrSyncDirection
  recordsTotal    Int             @default(0)
  recordsOk       Int             @default(0)
  recordsFailed   Int             @default(0)
  status          String          @default("pending") // pending | ok | partial | error
  errorMessage    String?
  payload         Json?

  @@index([integrationId, startedAt])
}

// =================================================================
//                  DISEASE DOCUMENTATION TEMPLATES
//
// Each row is a clinician-curated documentation skeleton that powers
// the "insert template" experience in the chart. AI never authors the
// final note — these are scaffolding for the provider.
// =================================================================

model DiseaseTemplate {
  id                String          @id @default(cuid())
  organizationId    String?         // null = system / starter template
  organization      Organization?   @relation(fields: [organizationId], references: [id])
  slug              String
  name              String
  category          String          // "Anterior segment" | "Posterior segment" | etc.
  // Sections are intentionally Json so practices can shape their own templates.
  hpiPrompts        String[]        @default([])
  examElements      String[]        @default([])
  assessmentOptions String[]        @default([])
  planOptions       String[]        @default([])
  educationPoints   String[]        @default([])
  codingSuggestions String[]        @default([])
  referralCriteria  String[]        @default([])
  followUpOptions   String[]        @default([])
  notes             String?
  isSystem          Boolean         @default(false)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  clinicalNotes     ClinicalNote[]

  @@unique([organizationId, slug])
  @@index([category])
}

// =================================================================
//                            INVENTORY
// =================================================================

model InventoryItem {
  id              String              @id @default(cuid())
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId      String?
  location        Location?           @relation(fields: [locationId], references: [id])
  category        InventoryCategory
  name            String
  brand           String?
  sku             String?
  description     String?
  vendor          String?
  costCents       Int                 @default(0)
  retailCents     Int                 @default(0)
  quantityOnHand  Int                 @default(0)
  reorderAt       Int                 @default(0)
  reorderQuantity Int                 @default(0)
  status          InventoryStatus     @default(ACTIVE)
  archivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  activity        InventoryActivity[]

  @@index([organizationId, category])
  @@index([organizationId, status])
  @@unique([organizationId, sku])
}

model InventoryActivity {
  id              String                @id @default(cuid())
  organizationId  String
  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itemId          String
  item            InventoryItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type            InventoryActivityType
  quantityDelta   Int
  reason          String?
  performedById   String?
  createdAt       DateTime              @default(now())

  @@index([organizationId, createdAt])
  @@index([itemId, createdAt])
}

// =================================================================
//                          AMBIENT SCRIBE
// =================================================================

model AmbientScribeSession {
  id              String              @id @default(cuid())
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patientId       String?
  patient         Patient?            @relation(fields: [patientId], references: [id])
  appointmentId   String?
  appointment     Appointment?        @relation(fields: [appointmentId], references: [id])
  providerId      String
  provider        User                @relation("ScribeProvider", fields: [providerId], references: [id])
  status          ScribeSessionStatus @default(IDLE)
  consentRecorded Boolean             @default(false)
  consentBy       String?             // "patient verbal" | "form signed" | etc.
  startedAt       DateTime?
  stoppedAt       DateTime?
  durationSeconds Int                 @default(0)
  generatedSoap   String?             @db.Text
  generatedPlan   String?             @db.Text
  generatedReferral String?           @db.Text
  generatedCoding String[]            @default([])
  chiefComplaint  String?             @db.Text
  hpi             String?             @db.Text
  examSummary     String?             @db.Text
  assessmentText  String?             @db.Text
  planText        String?             @db.Text
  patientInstructions String?         @db.Text
  followUpRecommendation String?      @db.Text
  aiConfidenceScore Float?
  reviewStatus    ScribeReviewStatus  @default(PROCESSING)
  reviewedById    String?
  reviewedBy      User?               @relation("ScribeReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  reviewComment   String?             @db.Text
  savedNoteId     String?             @unique
  audioBucket     String?
  audioPath       String?
  notes           String?
  archivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  segments        TranscriptSegment[]

  @@index([organizationId, providerId])
  @@index([organizationId, reviewStatus])
  @@index([organizationId, reviewStatus, archivedAt])
  @@index([patientId])
}

// =================================================================
//                    PLATFORM AI ASSISTANT
// =================================================================

model AiAssistantConversation {
  id              String              @id @default(cuid())
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String
  user            User                @relation("AssistantConversations", fields: [userId], references: [id], onDelete: Cascade)
  patientId       String?
  appointmentId   String?
  title           String              @default("New conversation")
  contextType     AssistantContextType @default(PLATFORM)
  archivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  messages        AiAssistantMessage[]

  @@index([organizationId, userId, updatedAt])
