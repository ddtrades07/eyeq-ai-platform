  channel         MessageChannel      @default(PORTAL)
  direction       MessageDirection
  body            String              @db.Text
  readStatus      MessageReadStatus   @default(UNREAD)
  readAt          DateTime?
  createdAt       DateTime            @default(now())

  @@index([threadId, createdAt])
  @@index([threadId, readStatus])
  @@index([readStatus])
}

// =================================================================
//                            DOCUMENTS
// =================================================================

model Document {
