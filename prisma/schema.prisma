  optOutAt        DateTime?
  notes           String?
  updatedAt       DateTime    @updatedAt

  @@index([organizationId])
}

model MessageDeliveryLog {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaignId      String?
  campaign        ReminderCampaign? @relation(fields: [campaignId], references: [id])
  patientId       String?
  channel         ReminderChannel
  status          DeliveryStatus  @default(QUEUED)
  vendor          String?         // "twilio-mock" | "ses-mock" | etc.
  vendorMessageId String?
  errorMessage    String?
  scheduledFor    DateTime?
  sentAt          DateTime?
  deliveredAt     DateTime?
  failedAt        DateTime?
  metadata        Json?
  createdAt       DateTime        @default(now())

  @@index([organizationId, status])
  @@index([campaignId])
  @@index([patientId])
}

// =================================================================
//                          INTERNATIONALIZATION
//
// We ship a TypeScript dictionary for compile-time safety; this table
// lets practices override individual strings without redeploying.
// =================================================================

model TranslationString {
  id              String          @id @default(cuid())
  organizationId  String?         // null = platform default
  organization    Organization?   @relation(fields: [organizationId], references: [id])
  locale          SupportedLocale
  namespace       String          // "ui" | "patient_education" | "reminders"
  key             String
  value           String          @db.Text
  reviewed        Boolean         @default(false)
  updatedAt       DateTime        @updatedAt

  @@unique([organizationId, locale, namespace, key])
  @@index([locale, namespace])
}

// =================================================================
//                 PATIENT BILLING AND INTAKE FORMS
// =================================================================

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
}

enum PatientFormStatus {
  PENDING
  COMPLETED
}

model PatientInvoice {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patientId       String
  patient         Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId   String?
  description     String
  totalCents      Int
  paidCents       Int             @default(0)
  status          InvoiceStatus   @default(OPEN)
  dueDate         DateTime?
  issuedAt        DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  claims          Claim[]
  ledgerEntries   PaymentLedgerEntry[]

  @@index([organizationId, status])
  @@index([patientId, status])
}

model PatientForm {
  id              String            @id @default(cuid())
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  title           String
  description     String?           @db.Text
  formType        String            @default("intake")
  status          PatientFormStatus @default(PENDING)
  responses       Json?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([organizationId, status])
  @@index([patientId, status])
}

// =================================================================
//                       FINANCIAL REPORTS
//
// Snapshots produced by the FinancialReport service. Reports are
// owner / admin scope only; permissions are enforced at the action
// layer. We persist snapshots so historical trends are stable even
// when underlying rows change.
// =================================================================

model FinancialReport {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  kind            String          // "operations" | "retention" | "inventory" | etc.
  periodStart     DateTime
  periodEnd       DateTime
  generatedById   String?
  generatedAt     DateTime        @default(now())
  payload         Json
  notes           String?

  @@index([organizationId, kind, periodStart])
}

// =================================================================
//                    AI GATEWAY INFRASTRUCTURE
// =================================================================

enum AiRequestType {
