// =================================================================
//                     ORGANIZATIONS & LOCATIONS
// =================================================================

model Organization {
  id                String              @id @default(cuid())
  name              String
  slug              String              @unique
  practiceMode      PracticeMode        @default(NATIVE_EHR)
  connectedEhr      ConnectedEhrVendor  @default(NONE)
  timezone          String              @default("America/Los_Angeles")
  defaultLocale     SupportedLocale     @default(EN)
  primaryColor      String?
  /// When true, staff must complete MFA (AAL2) before accessing PHI routes.
  mfaRequiredForStaff Boolean           @default(false)
  /// Explicit org opt-in to live PHI processing (still gated by env + BAAs).
  livePhiEnabled    Boolean             @default(false)
  /// Controlled live pilot for this org only (still requires readiness + livePhiEnabled).
  controlledPilotEnabled Boolean        @default(false)
  /// Set after ops verifies RLS SQL applied for this environment.
  rlsVerifiedAt     DateTime?
  /// Set when org confirms audit logging is monitored.
  auditVerifiedAt   DateTime?
  /// Admin-attested backup readiness (do not auto-claim).
  backupLastAt      DateTime?
  backupProvider    String?
  backupStatus      String?             // unknown | configured | verified | failed
  backupRetentionDays Int?
  backupRestoreTestAt DateTime?
  backupRestoreTestNotes String?        @db.Text
  /// Admin-attested monitoring readiness.
  monitoringVerifiedAt DateTime?
  monitoringProvider String?
  /// Admin-attested incident response review.
  incidentResponseReviewedAt DateTime?
  incidentResponseNotes String?         @db.Text
  /// Staff training / pilot launch attestation.
  staffTrainingCompletedAt DateTime?
  pilotLaunchNotes  String?             @db.Text
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  locations         Location[]
  users             User[]
  providers         Provider[]
  patients          Patient[]
  appointments      Appointment[]
  imagingCases      ImagingCase[]
  clinicalNotes     ClinicalNote[]
  prescriptions     Prescription[]
  careGaps          CareGap[]
  messageThreads    MessageThread[]
  documents         Document[]
  auditLogs         AuditLog[]
  ehrIntegrations   EhrIntegration[]
  diseaseTemplates  DiseaseTemplate[]
  inventoryItems    InventoryItem[]
  inventoryActivity InventoryActivity[]
  reminderTemplates ReminderTemplate[]
  reminderCampaigns ReminderCampaign[]
  scribeSessions    AmbientScribeSession[]
  assistantConversations AiAssistantConversation[]
  communicationPrefs CommunicationPreference[]
  deliveryLogs      MessageDeliveryLog[]
  translations      TranslationString[]
  financialReports  FinancialReport[]
  patientInvoices   PatientInvoice[]
  patientForms      PatientForm[]
  modelRegistry     ModelRegistry[]
  imagingAuditEvents ImagingAuditEvent[]
  aiGatewayRequests AiGatewayRequest[]
  aiProviderConfigs AiProviderConfig[]
  aiModelRoutes     AiModelRoute[]
  aiUsageRecords    AiUsageRecord[]
  phiDetectionEvents PhiDetectionEvent[]
  blockedAiRequests BlockedAiRequest[]
  aiKnowledgeDocuments AiKnowledgeDocument[]
  encounters        Encounter[]
  staffTasks        StaffTask[]
  backgroundJobs    BackgroundJob[]
  examCharts        ExamChart[]
  claims            Claim[]
  visitWorkflows    VisitWorkflowTemplate[]
  patientMerges     PatientMergeRecord[]
  remittances       RemittanceAdvice[]
  patientStatements PatientStatement[]
  migrationProjects MigrationProject[]
  opticalOrders     OpticalOrder[]
  opticalLabs       OpticalLab[]
  googleBusinessConnections GoogleBusinessConnection[]
  googleReviews     GoogleReview[]
  paymentLedgerEntries PaymentLedgerEntry[]
  stripeWebhookEvents StripeWebhookEvent[]
  appointmentRequests AppointmentRequest[]
  patientProxyAccess PatientProxyAccess[]
  vendorReadiness   VendorReadiness[]
  staffOnboardings  StaffOnboarding[]
  supportTickets    SupportTicket[]
  subscription      OrgSubscription?

  @@index([slug])
}

model Location {
  id              String        @id @default(cuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  shortName       String
  addressLine1    String?
  addressLine2    String?
  city            String?
  region          String?
  postalCode      String?
  country         String        @default("US")
  phone           String?
  rooms           Int           @default(1)
  isPrimary       Boolean       @default(false)
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  appointments    Appointment[]
  providers       Provider[]
  inventoryItems  InventoryItem[]
  userAccess      UserLocationAccess[]
  imagingCases    ImagingCase[]

  encounters      Encounter[]
  googleBusinessConnections GoogleBusinessConnection[]
  googleReviews   GoogleReview[]

  @@index([organizationId])
  @@index([organizationId, active])
}

/// Staff user access to one or more practice locations (multi-office RBAC).
model UserLocationAccess {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId     String
  location       Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@unique([userId, locationId])
  @@index([userId])
  @@index([locationId])
}

// =================================================================
//                              USERS
//
// Supabase Auth issues the auth user; we mirror the linkage here
// via `supabaseUserId`. One Supabase user = one EyeQ user. Multi-
// org membership is handled by OrganizationMembership.
// =================================================================

model User {
  id              String                    @id @default(cuid())
  supabaseUserId  String                    @unique
  email           String                    @unique
  firstName       String?
  lastName        String?
  avatarUrl       String?
  phone           String?
  defaultOrganizationId String?
  organizationId  String?
  organization    Organization?             @relation(fields: [organizationId], references: [id])
  role            Role                      @default(PATIENT)
  preferredLocale SupportedLocale           @default(EN)
  isActive        Boolean                   @default(true)
  lastSeenAt      DateTime?
  mfaEnrolledAt   DateTime?
  mfaLastVerifiedAt DateTime?
  staffOnboarding StaffOnboarding?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  memberships     OrganizationMembership[]
  provider        Provider?
  patient         Patient?                  @relation("PatientUser")
  authoredNotes   ClinicalNote[]            @relation("AuthorNotes")
  signedNotes     ClinicalNote[]            @relation("SignerNotes")
  uploadedImaging ImagingCase[]             @relation("UploaderImaging")
  signedImaging   ImagingCase[]             @relation("SignerImaging")
  sentMessages    Message[]                 @relation("SenderMessages")
  scribeSessions  AmbientScribeSession[]    @relation("ScribeProvider")
  scribeReviews   AmbientScribeSession[]    @relation("ScribeReviewer")
  assistantConversations AiAssistantConversation[] @relation("AssistantConversations")
  auditLogs       AuditLog[]
  locationAccess  UserLocationAccess[]
  providerImagingReviews ProviderImagingReview[] @relation("ProviderImagingReviews")
  imagingAuditEvents ImagingAuditEvent[] @relation("ImagingAuditUser")
  aiGatewayRequests AiGatewayRequest[] @relation("AiGatewayRequests")
  assignedTasks     StaffTask[] @relation("AssignedTasks")
  createdTasks      StaffTask[] @relation("CreatedTasks")
  reviewDrafts      GoogleReview[] @relation("ReviewDraftAuthor")
  reviewPublishes   GoogleReview[] @relation("ReviewPublishAuthor")
  signedPrescriptions Prescription[] @relation("PrescriptionSigner")
  paymentLedgerEntries PaymentLedgerEntry[] @relation("PaymentLedgerActor")
  appointmentRequestsHandled AppointmentRequest[] @relation("AppointmentRequestHandler")
  guardianProxyAccess PatientProxyAccess[] @relation("GuardianProxyAccess")
  supportTicketsCreated SupportTicket[] @relation("SupportTicketCreator")
  supportTicketsAssigned SupportTicket[] @relation("SupportTicketAssignee")
  supportTicketNotes SupportTicketNote[] @relation("SupportTicketNoteAuthor")

  @@index([organizationId])
  @@index([role])
}

model OrganizationMembership {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId  String
  role            Role
  isPrimary       Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// =================================================================
//                            PROVIDERS
// =================================================================

model Provider {
  id              String        @id @default(cuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentials     String?
  npi             String?
  title           String?
  locations       Location[]
  appointments    Appointment[]
  encounters      Encounter[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId])
}

// =================================================================
//                             PATIENTS
// =================================================================

model Patient {
  id                String          @id @default(cuid())
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId            String?         @unique
  user              User?           @relation("PatientUser", fields: [userId], references: [id])
  externalId        String?         // EHR MRN when in Connected mode
  firstName         String
  lastName          String
  dateOfBirth       DateTime
  email             String?
  phone             String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  region            String?
  postalCode        String?
  country           String          @default("US")
  insuranceCarrier  String?
  insuranceMemberId String?
  insuranceStatus   String?
  preferredLanguage String          @default("en")
  preferredLocale   SupportedLocale @default(EN)
  hasDiabetes       Boolean         @default(false)
  hasHypertension   Boolean         @default(false)
  hasGlaucomaPersonal Boolean       @default(false)
  hasGlaucomaFamily Boolean         @default(false)
  isSmoker          Boolean         @default(false)
  notes             String?
  archivedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  appointments      Appointment[]
  imagingCases      ImagingCase[]
  clinicalNotes     ClinicalNote[]
  prescriptions     Prescription[]
  careGaps          CareGap[]
  messageThreads    MessageThread[]
  documents         Document[]
  scribeSessions    AmbientScribeSession[]
  invoices          PatientInvoice[]
  forms             PatientForm[]
  communicationPref CommunicationPreference?
  encounters        Encounter[]
  staffTasks        StaffTask[]
  examCharts        ExamChart[]
  claims            Claim[]
  statements        PatientStatement[]
  opticalOrders     OpticalOrder[]
  appointmentRequests AppointmentRequest[]
  proxyAccessAsPatient PatientProxyAccess[] @relation("ProxyPatient")
  paymentLedgerEntries PaymentLedgerEntry[]
  mergedIntoId      String?
  mergedInto        Patient?          @relation("PatientMerge", fields: [mergedIntoId], references: [id])
  mergedFrom        Patient[]         @relation("PatientMerge")

  @@index([organizationId])
  @@index([organizationId, archivedAt])
  @@index([organizationId, lastName, firstName])
  @@index([organizationId, externalId])
  @@index([userId])
  @@index([mergedIntoId])
}

// =================================================================
//                          APPOINTMENTS
// =================================================================

model Appointment {
  id                String              @id @default(cuid())
  organizationId    String
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId        String?
  location          Location?           @relation(fields: [locationId], references: [id])
  patientId         String
  patient           Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  providerId        String?
  provider          Provider?           @relation(fields: [providerId], references: [id])
  type              AppointmentType
  status            AppointmentStatus   @default(SCHEDULED)
  startsAt          DateTime
  endsAt            DateTime
  durationMinutes   Int                 @default(45)
  room              String?
  reason            String?
  notes             String?
  intakeStatus      String              @default("NotStarted")
  pretestComplete   Boolean             @default(false)
  dilationNeeded    Boolean             @default(false)
  dilationStartedAt DateTime?
  imagingNeeded     String[]            @default([])
  opticalHandoffPending Boolean         @default(false)
  noShowRiskScore   Float?
  complexity        String?
  source            String              @default("native") // native | imported
  cancelReason      String?
  externalRef       String?             // EHR appointment ID
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  imagingCases      ImagingCase[]
  clinicalNotes     ClinicalNote[]
  scribeSessions    AmbientScribeSession[]
  encounter         Encounter?
  appointmentRequest AppointmentRequest?

  @@index([organizationId, startsAt])
  @@index([organizationId, status])
  @@index([organizationId, locationId, startsAt])
  @@index([organizationId, status, startsAt])
  @@index([patientId, startsAt])
  @@index([patientId])
  @@index([providerId])
  @@index([locationId])
}

model Encounter {
  id                String            @id @default(cuid())
  organizationId    String
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId        String?
  location          Location?         @relation(fields: [locationId], references: [id])
  patientId         String
  patient           Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId     String            @unique
  appointment       Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  providerId        String?
  provider          Provider?         @relation(fields: [providerId], references: [id])
  status            EncounterStatus   @default(SCHEDULED)
  checkedInAt       DateTime?
  pretestStartedAt  DateTime?
  providerStartedAt DateTime?
  documentationStartedAt DateTime?
  completedAt       DateTime?
  primaryNoteId     String?
  createdById       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tasks             StaffTask[]
  examChart         ExamChart?

  @@index([organizationId, status])
  @@index([organizationId, locationId, status])
  @@index([organizationId, status, updatedAt])
  @@index([patientId])
  @@index([appointmentId])
}

model StaffTask {
  id              String            @id @default(cuid())
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId      String?
  patientId       String?
  patient         Patient?          @relation(fields: [patientId], references: [id], onDelete: SetNull)
  encounterId     String?
  encounter       Encounter?        @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  appointmentId   String?
  assignedToId    String?
  assignedTo      User?             @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdById     String?
  createdBy       User?             @relation("CreatedTasks", fields: [createdById], references: [id])
  title           String
  description     String?           @db.Text
  status          StaffTaskStatus   @default(OPEN)
  priority        StaffTaskPriority @default(NORMAL)
  dueAt           DateTime?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([organizationId, status])
  @@index([assignedToId, status])
  @@index([patientId])
}

// =================================================================
//                          IMAGING CASES
// =================================================================

model ImagingCase {
  id                String              @id @default(cuid())
  organizationId    String
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId        String?
  location          Location?           @relation(fields: [locationId], references: [id])
  patientId         String
  patient           Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId     String?
  appointment       Appointment?        @relation(fields: [appointmentId], references: [id])
  uploaderId        String
  uploader          User                @relation("UploaderImaging", fields: [uploaderId], references: [id])
  imageType         ImageType
  confirmedModality ImageType?
  laterality        ImagingLaterality   @default(UNKNOWN)
  bodyRegion        String?
  storagePath       String
  fileName          String?
  fileSizeBytes     Int?
  mimeType          String?
  checksum          String?
  thumbnailPath     String?
  previewPath       String?
  capturedAt        DateTime            @default(now())
  status            ImagingStatus       @default(AWAITING_AI)
  studyStatus       ImagingStudyStatus  @default(UPLOADED)
  aiQuality         String?
  aiAnatomyDetected String[]            @default([])
  aiFlags           String[]            @default([])
  aiUrgency         String?
  aiConfidence      String?
  aiNotes           String[]            @default([])
  aiInvokedAt       DateTime?
  aiProvider        String?
  analysisMode      String?
  providerNote      String?             @db.Text
  patientSummary    String?             @db.Text
  patientSummaryApprovedAt DateTime?
  signedById        String?
  signedBy          User?               @relation("SignerImaging", fields: [signedById], references: [id])
  signedAt          DateTime?
  trend             String?
  needsFollowUp     Boolean             @default(false)
  followUpNote      String?             @db.Text
  archivedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  assets            ImagingAsset[]
  qualityAssessments ImageQualityAssessment[]
  analyses          ImagingAnalysis[]
  providerReviews   ProviderImagingReview[]
  imagingAuditEvents ImagingAuditEvent[]

  @@index([organizationId, capturedAt])
  @@index([organizationId, studyStatus])
  @@index([organizationId, archivedAt, studyStatus])
  @@index([organizationId, archivedAt, capturedAt])
  @@index([organizationId, locationId, capturedAt])
  @@index([patientId, capturedAt])
  @@index([appointmentId])
  @@index([locationId])
  @@index([status])
}

model ImagingAsset {
  id               String      @id @default(cuid())
  imagingCaseId    String
  imagingCase      ImagingCase @relation(fields: [imagingCaseId], references: [id], onDelete: Cascade)
  storagePath      String
  originalFilename String?
  mimeType         String?
  fileSizeBytes    Int?
  checksum         String?
  width            Int?
  height           Int?
  pageCount        Int?
  thumbnailPath    String?
  previewPath      String?
  isOriginal       Boolean     @default(true)
  metadata         Json?
  uploadedAt       DateTime    @default(now())

  qualityAssessments ImageQualityAssessment[]

  @@index([imagingCaseId])
  @@index([checksum])
}

model ImageQualityAssessment {
  id                  String       @id @default(cuid())
  imagingCaseId       String
  imagingCase         ImagingCase  @relation(fields: [imagingCaseId], references: [id], onDelete: Cascade)
  imagingAssetId      String?
  imagingAsset        ImagingAsset? @relation(fields: [imagingAssetId], references: [id])
  grade               QualityGrade
  overallScore        Int
  focusScore          Int?
  illuminationScore   Int?
  contrastScore       Int?
  fieldOfViewScore    Int?
  centeringScore      Int?
  artifactScore       Int?
  segmentationQuality Int?
  qualityLimitations  String[]     @default([])
  retakeRecommended   Boolean      @default(false)
  createdAt           DateTime     @default(now())

  @@index([imagingCaseId])
}

model ImagingAnalysis {
  id                    String                @id @default(cuid())
  imagingCaseId         String
  imagingCase           ImagingCase           @relation(fields: [imagingCaseId], references: [id], onDelete: Cascade)
  analysisProvider      String
  modelName             String?
  modelVersion          String?
  supportedIntendedUse  String?
  analysisStatus        ImagingAnalysisStatus @default(PENDING)
  startedAt             DateTime?
  completedAt           DateTime?
  failedAt              DateTime?
  failureReason         String?
  processingTimeMs      Int?
  outOfDistribution     Boolean               @default(false)
  requiresManualReview  Boolean               @default(false)
  isDevelopmentMock     Boolean               @default(false)
  rawProviderResponse   Json?
  createdAt             DateTime              @default(now())

  findings              ImagingFinding[]

  @@index([imagingCaseId])
  @@index([analysisStatus])
}

model ImagingFinding {
  id                  String          @id @default(cuid())
  imagingAnalysisId   String
  imagingAnalysis     ImagingAnalysis @relation(fields: [imagingAnalysisId], references: [id], onDelete: Cascade)
  findingCode         String?
  findingLabel        String
  anatomicalLocation  String?
  laterality          ImagingLaterality?
  evidenceDescription String?
  confidenceCategory  String
  probability         Float?
  severityCategory    String?
  actionCategory      String?
  limitations         String[]        @default([])
  supportedByModel    Boolean         @default(true)
  createdAt           DateTime        @default(now())

  @@index([imagingAnalysisId])
}

model ProviderImagingReview {
  id                    String               @id @default(cuid())
  imagingCaseId         String
  imagingCase           ImagingCase          @relation(fields: [imagingCaseId], references: [id], onDelete: Cascade)
  providerId            String
  provider              User                 @relation("ProviderImagingReviews", fields: [providerId], references: [id])
  reviewStatus          ProviderReviewStatus @default(PENDING)
  agreesWithAI          Boolean?
  acceptedFindingIds    String[]             @default([])
  rejectedFindingIds    String[]             @default([])
  editedFindings        Json?
  providerInterpretation String?             @db.Text
  followUpPlan          String?              @db.Text
  referralPlan          String?              @db.Text
  patientSummary        String?              @db.Text
  signedAt              DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([imagingCaseId])
  @@index([providerId])
}

model ModelRegistry {
  id                            String                @id @default(cuid())
  organizationId                String?
  organization                  Organization?         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerName                  String
  modelName                     String
  modelVersion                  String
  supportedModalities           ImageType[]
  supportedFindings             String[]              @default([])
  intendedUse                   String?
  validationStatus              ModelValidationStatus @default(UNVALIDATED)
  enabled                       Boolean               @default(false)
  endpointConfigurationReference String?
