  organizationId  String?
  organization    Organization?   @relation(fields: [organizationId], references: [id])
  userId          String?
  user            User?           @relation(fields: [userId], references: [id])
  patientId       String?
  action          AuditAction
  resourceType    String
  resourceId      String?
  success         Boolean         @default(true)
  previousStatus  String?
  newStatus       String?
  ipAddress       String?
